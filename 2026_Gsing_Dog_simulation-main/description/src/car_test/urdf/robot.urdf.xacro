<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="my_bot">

    <xacro:include filename="inertia_macros.xacro" />
    <xacro:include filename="camera.xacro" />
    <xacro:include filename="gazebo_control.xacro" />

    <material name="white">
        <color rgba="1 1 1 1" />
    </material>
    <material name="black">
        <color rgba="0 0 0 1" />
    </material>

    <link name="base_link">
    </link>

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="-0.1 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.1 0 0.075"/>
            <geometry>
                <box size="0.5 0.3 0.15"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0.1 0 0.075"/>
            <geometry>
                <box size="0.5 0.3 0.15"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="2.0" x="0.5" y="0.3" z="0.15">
            <origin xyz="0.1 0 0.075" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- 修正：轮子宏定义 - 修改轴方向为绕Y轴旋转 -->
    <xacro:macro name="wheel" params="name x y z">
        <link name="${name}_wheel">
            <visual>
                <geometry>
                    <cylinder radius="0.05" length="0.04"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="0.05" length="0.04"/>
                </geometry>
            </collision>
            <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.05">
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </xacro:inertial_cylinder>
        </link>

        <!-- 修正：将轴从 0 0 1 改为 0 1 0（绕Y轴旋转） -->
        <joint name="${name}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${name}_wheel"/>
            <origin xyz="${x} ${y} ${z}" rpy="-${pi/2} 0 0" />
            <axis xyz="0 0 1"/>  <!-- 修改这里：从 0 0 1 改为 0 1 0 -->
        </joint>
    </xacro:macro>

    <xacro:wheel name="rear_left"  x="0.0"  y="0.175" z="0.0" />
    <xacro:wheel name="rear_right" x="0.0"  y="-0.175" z="0.0" />
    <xacro:wheel name="front_left" x="0.3"  y="0.175" z="0.0" />
    <xacro:wheel name="front_right" x="0.3" y="-0.175" z="0.0" />

    <gazebo reference="front_left_wheel">
        <mu1>0.01</mu1>
        <mu2>0.01</mu2>
    </gazebo>
    <gazebo reference="front_right_wheel">
        <mu1>0.01</mu1>
        <mu2>0.01</mu2>
    </gazebo>

    <xacro:camera_sensor />

</robot>